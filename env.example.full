# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/admetrics

# ─── BigQuery ──────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
BQ_PROJECT_ID=ad-metrics-pipeline

# ─── DRL Model ─────────────────────────────────────────
DRL_MODEL_DIR=models/drl          # Directory where .pt model files are stored
DRL_STATE_DIM=39                  # 33 base + 3 spend + 3 audience segmentation
DRL_DEVICE=cpu                    # cpu or cuda
DRL_ENABLED=True                  # Set False to use rule-based fallback only
DRL_MIN_CONFIDENCE=0.7            # Below this, action requires human review
DRL_AUTO_APPLY_THRESHOLD=0.85     # Above this, action can be auto-applied
DRL_INFERENCE_TIMEOUT_MS=100      # Max inference latency before timeout
DRL_GUARDRAIL_MAX_BID_ADJ=0.5    # Max bid adjustment magnitude
DRL_GUARDRAIL_MAX_BUDGET_ADJ=0.3 # Max budget adjustment magnitude

# ─── Continuous Learning ────────────────────────────────
CONTINUOUS_LEARNING_MODE=hybrid   # online, batch, triggered, hybrid
CONTINUOUS_LEARNING_THRESHOLD=1000 # Retrain after N recorded outcomes
RETRAIN_SCHEDULE_HOURS=24         # Hours between scheduled retrains

# ─── Platform API Keys ─────────────────────────────────
GOOGLE_ADS_API_KEY=
GOOGLE_ADS_CUSTOMER_ID=
META_MARKETING_API_KEY=
TIKTOK_BUSINESS_API_KEY=
AMAZON_ADVERTISING_API_KEY=
AMAZON_CLIENT_ID=
LINKEDIN_MARKETING_API_KEY=

# ─── Data Pipeline ──────────────────────────────────────
DATA_PIPELINE_FETCH_TIMEOUT_SECONDS=30
DATA_PIPELINE_RETRY_MAX_ATTEMPTS=3
DATA_PIPELINE_RETRY_BACKOFF_MS=1000

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DRL_INFERENCE=TRUE
LOG_PLATFORM_API_CALLS=TRUE

# ─── API ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
